{
  "name": "clawvs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "tools:check:url": "node scripts/check-urls.mjs",
    "tools:sync:github": "node scripts/sync-github-metadata.mjs",
    "tools:index:generate": "node scripts/generate-tools-index.mjs",
    "prebuild": "bun run tools:index:generate",
    "predev": "bun run tools:index:generate",
    "pretypes:check": "bun run tools:index:generate",
    "build": "rm -rf out && next build",
    "dev": "next dev",
    "start": "next start",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@takumi-rs/image-response": "^0.73.1",
    "@tanstack/react-table": "^8.21.3",
    "@types/three": "^0.183.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fumadocs-core": "16.7.4",
    "fumadocs-mdx": "14.2.11",
    "fumadocs-ui": "16.7.4",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-force-graph-2d": "^1.29.1",
    "react-force-graph-3d": "^1.29.1",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "three-spritetext": "^1.10.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  }
